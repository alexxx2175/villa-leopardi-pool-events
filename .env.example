# SENDER_EMAIL: Mittente email. Prima di verificare il dominio, usare "Villa Leopardi <onboarding@resend.dev>".
SENDER_EMAIL="Villa Leopardi <onboarding@resend.dev>"

# ADMIN_EMAIL: Email che riceve tutte le prenotazioni.
